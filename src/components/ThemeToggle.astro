---
/**
 * Global theme toggle. Toggles awsui-dark-mode class on <html> and persists to localStorage.
 * Uses inline script to avoid hydration — works immediately on page load.
 */
---
<button class="theme-toggle" aria-label="Toggle dark mode" type="button">
  <span class="theme-toggle__icon theme-toggle__icon--light">☀️</span>
  <span class="theme-toggle__icon theme-toggle__icon--dark">🌙</span>
</button>

<script is:inline>
  (function () {
    const btn = document.querySelector('.theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.toggle('awsui-dark-mode');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  })();
</script>

<style>
  .theme-toggle {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 1000;
    border: 1px solid var(--color-border-divider-default, #e9ebed);
    border-radius: 8px;
    background: var(--color-background-layout-main, #ffffff);
    padding: 6px 10px;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
  }

  .theme-toggle__icon--dark { display: none; }

  :global(.awsui-dark-mode) .theme-toggle__icon--light { display: none; }
  :global(.awsui-dark-mode) .theme-toggle__icon--dark { display: inline; }
</style>
