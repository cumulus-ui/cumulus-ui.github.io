---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { displayName } from '@/utils/display-name';

const components = (await getCollection('components')).sort((a, b) => a.data.component.localeCompare(b.data.component));
const breadcrumbs = [
  { text: 'Home', href: '/' },
  { text: 'Components', href: '/components' },
];
---
<BaseLayout title="Components" breadcrumbs={breadcrumbs}>
  <cs-content-layout default-padding>
    <cs-header slot="header" variant="h1" description={`${components.length} components available.`}>
      Components
    </cs-header>
    <cs-space-between size="l" direction="vertical">
      <cs-alert type="info" status-icon-aria-label="Info">
        Cumulus UI is pre-release software. Expect breaking changes before 1.0.
      </cs-alert>
      <div class="tiles-grid">
        {components.map(comp => (
            <a href={`/components/${comp.id}`} class="tile-link">
              <cs-container fit-height>
                <cs-header slot="header" description={comp.data.description}>
                  {displayName(comp.data.component)}
                </cs-header>
                <code>&lt;cs-{comp.data.component}&gt;</code>
              </cs-container>
            </a>
        ))}
      </div>
    </cs-space-between>
  </cs-content-layout>
</BaseLayout>

<style>
  .tiles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-s);
  }
  .tile-link {
    display: grid;
    text-decoration: none;
  }
</style>
