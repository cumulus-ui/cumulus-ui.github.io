---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { displayName } from '@/utils/display-name';

export async function getStaticPaths() {
  const components = await getCollection('components');
  return components.map(comp => ({
    params: { name: comp.id },
    props: { comp },
  }));
}

const { comp } = Astro.props;
const { Content } = await render(comp);
const title = displayName(comp.data.component);

const breadcrumbs = [
  { text: 'Home', href: '/' },
  { text: 'Components', href: '/components' },
  { text: title, href: `/components/${comp.id}` },
];
---
<BaseLayout title={title} breadcrumbs={breadcrumbs} activeComponentId={comp.id}>
  <cs-content-layout default-padding max-content-width="1440">
    <cs-header slot="header" variant="h1" description={`${comp.data.description} — <cs-${comp.data.component}>`}>
      {title}
    </cs-header>
    <Content />
  </cs-content-layout>
</BaseLayout>
